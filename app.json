{
  "expo": {
    "name": "KothaBill",
    "slug": "kothabill",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kothabill.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D9E75"
      },
      "package": "com.kothabill.app"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1D9E75",
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "scheme": "kothabill",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
