{
  "expo": {
    "name": "KothaBill",
    "slug": "kothabill",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1D9E75",
      "dark": {
        "image": "./assets/splash-dark.png",
        "backgroundColor": "#121212"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kothabill.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1D9E75"
      },
      "package": "com.kothabill.app"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1D9E75",
          "image": "./assets/splash.png",
          "dark": {
            "image": "./assets/splash-dark.png",
            "backgroundColor": "#121212"
          },
          "resizeMode": "contain"
        }
      ],
      "expo-font"
    ],
    "scheme": "kothabill",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
